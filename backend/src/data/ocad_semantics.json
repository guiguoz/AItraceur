  "terrain_type_groups": {
    "impassable": ["water_uncrossable", "marsh_uncrossable", "impassable", "fight", "forbidden", "private", "dangerous", "cliff", "building"],
    "very_slow": ["marsh", "walk", "fight", "shallow_water"],
    "slow": ["rock_field", "slow_run", "obstacle", "cultivated_slow"],
    "normal_forest": ["forest"],
    "open": ["open", "semi_open", "rough_open", "rough_semi_open"],
    "path_network": ["path", "narrow_path", "wide_path", "road", "road_paved", "poor_path"],
    "water_features": ["water_uncrossable", "water_surface", "marsh_uncrossable", "marsh", "stream_crossable", "stream_small"],
    "distinctive_point_features": ["rock_point", "depression", "rock_depression"]
  },

  "td_rules": {
    "TD1": {
      "description": "Très facile — Blanc/Jaune",
      "max_leg_length_m": 200,
      "features": ["path", "wide_path", "road", "open"],
      "notes": "Postes uniquement sur carrefours de sentiers ou clairières. Pas de boussole nécessaire."
    },
    "TD2": {
      "description": "Facile — Jaune",
      "max_leg_length_m": 350,
      "features": ["path", "wide_path", "vegetation_boundary", "stream_crossable"],
      "notes": "Postes sur features linéaires. Navigation simple le long de lignes directrices."
    },
    "TD3": {
      "description": "Moyen — Orange",
      "max_leg_length_m": 700,
      "features": ["contour", "rock_point", "depression", "stream_small"],
      "notes": "Postes sur features de contour ou ponctuels. Boussole utile. Points d'attaque requis."
    },
    "TD4": {
      "description": "Difficile — Vert",
      "max_leg_length_m": 1500,
      "features": ["contour", "rock_point", "depression", "wall"],
      "notes": "Postes sur tout type de feature. Longues jambes sur boussole. Terrain technique."
    },
    "TD5": {
      "description": "Très difficile — Bleu/Noir",
      "max_leg_length_m": 9999,
      "features": ["contour", "rock_point", "depression"],
      "notes": "Postes sur features peu distinctifs. Terrain très technique, longues distances sans directeur."
    }
  },

  "pd_rules": {
    "PD1": {
      "description": "Très facile physiquement",
      "max_climb_ratio": 0.01,
      "terrain": ["open", "path_network"],
