# =============================================
# AItraceur - Variables d'environnement
# Copier ce fichier vers .env et remplir les valeurs
# =============================================

# === Base de données ===
DATABASE_URL=postgresql://aitraceur:aitraceur@localhost:5432/aitraceur

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Configuration FastAPI ===
LOG_LEVEL=INFO
DEBUG=true

# === Upload ===
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=52428800  # 50 MB

# === Options OCAD ===
# Version OCAD supportée (pour le parser)
OCAD_SUPPORTED_VERSION=12

# === API Externe (pour plus tard) ===
# OPENAI_API_KEY=sk-...
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter
