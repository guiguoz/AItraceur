    },
    "PD2": {
      "description": "Facile physiquement",
      "max_climb_ratio": 0.02,
      "terrain": ["open", "forest", "path_network"],
      "notes": "Légère montée, terrain courrable."
    },
    "PD3": {
      "description": "Moyen physiquement",
      "max_climb_ratio": 0.04,
      "terrain": ["forest", "semi_open"],
      "notes": "Dénivelé modéré. Limite IOF standard pour parcours compétition."
    },
    "PD4": {
      "description": "Difficile physiquement",
      "max_climb_ratio": 0.06,
      "terrain": ["forest", "slow_run"],
      "notes": "Fort dénivelé, terrain contraignant. Dépasse la limite IOF recommandée."
    },
    "PD5": {
      "description": "Très difficile physiquement",
      "max_climb_ratio": 9999,
